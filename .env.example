# PostgreSQL — used by Next.js gateway (Prisma) and Python worker
# For Neon/pgBouncer: DATABASE_URL = pooled, DATABASE_URL_UNPOOLED = direct (for migrations)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ops_workflow"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/ops_workflow"

# Redis — used by Next.js gateway (ioredis) and Python worker (redis-py)
REDIS_URL="redis://localhost:6379"

# Python worker identity (each replica should have a unique name)
WORKER_CONSUMER_NAME="worker-1"

# Next.js (optional — defaults work for local dev)
# NODE_ENV=development
# PORT=3000
